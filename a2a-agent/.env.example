# ============================================
# A2A Customer Support Agent Configuration
# ============================================

# Server Configuration
# --------------------
# The public URL where the agent will be accessible
SERVER_URL=http://localhost:9999

# Port for the agent server to listen on
PORT=9999

# Yandex Cloud Configuration
# ---------------------------
# Yandex Cloud API key for authentication
# Get it from: https://cloud.yandex.com/en/docs/iam/operations/api-key/create
API_KEY=

# Yandex Cloud folder ID where your resources are located
# Find it in the cloud console URL or via CLI: yc config list
FOLDER_ID=

# Vector Store ID for file search tool (optional)
# Create a vector store in Yandex Cloud and get its ID
VECTOR_STORE_ID=

# Airline API Configuration
# -------------------------
# URL of the airline-api service for fetching customer profiles
# Example: http://localhost:8001
AIRLINE_API_URL=

# MCP Server Configuration (Optional)
# ------------------------------------
# URL of the MCP (Model Context Protocol) server for additional agent tools
# Example: https://your-mcp-server.example.com/sse
MCP_SERVER_URL=

# ============================================
# Optional: Additional Settings
# ============================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Enable verbose agent logging
# VERBOSE_LOGGING=false
