# ============================================
# ChatKit Customer Support Agent Configuration
# ============================================

# Server Configuration
# --------------------
# Port for the agent server to listen on
PORT=8000


# Yandex Cloud Configuration
# ---------------------------
# Yandex Cloud API key for authentication
# Get it from: https://cloud.yandex.com/en/docs/iam/operations/api-key/create
API_KEY=your-yandex-api-key-here

# Yandex Cloud folder ID where your resources are located
# Find it in the cloud console URL or via CLI: yc config list
FOLDER_ID=your-yandex-folder-id-here

# Vector Store ID for file search tool (optional)
# Create a vector store in Yandex Cloud and get its ID
# Leave empty to disable file search functionality
VECTOR_STORE_ID=


# Airline API Configuration
# -------------------------
# URL of the airline-api service for fetching customer profiles
# For local development: http://localhost:8001
# For Docker Compose: http://airline-api:8001
AIRLINE_API_URL=http://localhost:8001


# Store Configuration
# -------------------
# Use in-memory store (true) or DynamoDB (false)
USE_MEMORY_STORE=true


# MCP Server Configuration (Optional)
# ------------------------------------
# URL of the MCP (Model Context Protocol) server for additional agent tools
# Leave empty to disable MCP integration
# Example: https://your-mcp-server.example.com/sse
MCP_SERVER_URL=


# ============================================
# DynamoDB Configuration (if USE_MEMORY_STORE=false)
# ============================================

# AWS Region
# AWS_REGION=us-east-1

# AWS Credentials (for AWS DynamoDB)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Yandex Cloud credentials (for Yandex Managed YDB)
# YC_ACCESS_KEY_ID=your-yandex-access-key
# YC_SECRET_ACCESS_KEY=your-yandex-secret-key

# DynamoDB table prefix
# DYNAMODB_TABLE_PREFIX=airline

# Auto-create tables if they don't exist
# AUTO_CREATE_TABLES=true

# DynamoDB endpoint URL (for local development)
# DYNAMODB_ENDPOINT_URL=http://localhost:8000


# ============================================
# Optional: Additional Settings
# ============================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Enable verbose agent logging
# VERBOSE_LOGGING=false
